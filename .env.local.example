NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# Canonical app URL for operator signup links, emails, etc. (defaults to browser origin if unset)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Booking / analytics API (Cloud Functions v2 / Cloud Run URL)
NEXT_PUBLIC_FUNCTIONS_BASE_URL=https://asia-southeast1-<project-id>.cloudfunctions.net/api

# Set to true to point Firebase SDK at local emulators instead of production
NEXT_PUBLIC_USE_EMULATOR=false

# Force analytics sampling in dev (set true to test analytics locally)
NEXT_PUBLIC_ANALYTICS_FORCE_SAMPLE=false

# WeatherAPI.com — free commercial tier (1M calls/month)
# Get key at https://www.weatherapi.com/signup.aspx
NEXT_PUBLIC_WEATHERAPI_KEY=

# Comma-separated origins allowed for cross-origin dev access (LAN testing, etc.)
NEXT_ALLOWED_DEV_ORIGINS=http://localhost:3000
