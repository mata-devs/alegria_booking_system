rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSuperAdmin() {
      return request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'super_admin';
    }

    function isOperator() {
      return request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'operator';
    }

    function isOwnUserDoc(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    // Added 2026-05-20 — ISSUE-001a: dotProofUrl; ISSUE-001c: customInclusionChips/customExclusionChips
    // Updated 2026-05-22 — ISSUE-007: include phoneNumber/mobileNumber written by operator settings page
    function isAllowedSelfUserUpdate() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly([
        'firstName',
        'lastName',
        'phoneNumber',
        'mobileNumber',
        'paymentMethods',
        'dotProofUrl',
        'customInclusionChips',
        'customExclusionChips',
      ]);
    }

    // Updated 2026-05-22 — ISSUE-007: only validate chip shape when the chip field is actually changing,
    // so updates that don't touch the chip arrays don't fail when the existing doc has no chips set.
    function customInclusionChipsShapeOk() {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny(['customInclusionChips'])
        || (request.resource.data.customInclusionChips is list
            && request.resource.data.customInclusionChips.size() <= 50);
    }

    function customExclusionChipsShapeOk() {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny(['customExclusionChips'])
        || (request.resource.data.customExclusionChips is list
            && request.resource.data.customExclusionChips.size() <= 50);
    }

    // Added 2026-05-20 — ISSUE-001a: DOT Quality Seal (display-only; operators cannot self-grant)
    function operatorSealFieldsUnchanged() {
      return request.resource.data.get('hasDOTQualitySeal', false) == resource.data.get('hasDOTQualitySeal', false)
        && request.resource.data.get('dotSealGrantedAt', null) == resource.data.get('dotSealGrantedAt', null)
        && request.resource.data.get('dotSealGrantedByUid', null) == resource.data.get('dotSealGrantedByUid', null);
    }

    function bookingSourceType() {
      return request.resource.data.sourceType;
    }

    function bookingSourceId() {
      return request.resource.data.activityId;
    }

    function bookingOperatorUid() {
      return request.resource.data.operatorUid;
    }

    function bookingMatchesSourceOwner() {
      return (bookingSourceType() == 'activity'
          && bookingOperatorUid() == get(/databases/$(database)/documents/activities/$(bookingSourceId())).data.operatorId)
        || (bookingSourceType() == 'tourPackage'
          && bookingOperatorUid() == get(/databases/$(database)/documents/tourPackages/$(bookingSourceId())).data.operatorId);
    }

    // ── ADDED 2026-04-24 ───────────────────────────────────────────
    // Activities: public read for guest catalog. Only the owning operator can
    // create/edit/delete their own activities. Super admins and guests are read-only.
    match /activities/{activityId} {
      allow read: if true;
      // Added 2026-05-20 — ISSUE-001c: structured inclusions/exclusions must be lists
      allow create: if isOperator()
        && request.resource.data.operatorId == request.auth.uid
        && request.resource.data.inclusions is list
        && request.resource.data.exclusions is list;
      // Updated 2026-05-22 — ISSUE-007: split update/delete so delete doesn't reference request.resource
      allow update: if isOperator()
        && resource.data.operatorId == request.auth.uid
        && request.resource.data.inclusions is list
        && request.resource.data.exclusions is list;
      allow delete: if isOperator()
        && resource.data.operatorId == request.auth.uid;
    }
    // ── ADDED 2026-04-24 ───────────────────────────────────────────
    // Tour packages: public read for guest catalog. Only the owning operator can
    // create/edit/delete their own packages. Super admins have full write access.
    match /tourPackages/{packageId} {
      allow read: if true;
      // Added 2026-05-20 — ISSUE-001b: packageLocations (≥1 municipality); ISSUE-001c: inclusions/exclusions lists
      allow create: if isOperator()
        && request.resource.data.operatorId == request.auth.uid
        && request.resource.data.packageLocations is list
        && request.resource.data.packageLocations.size() >= 1
        && request.resource.data.inclusions is list
        && request.resource.data.exclusions is list;
      // Updated 2026-05-22 — ISSUE-007: split update/delete so delete doesn't reference request.resource
      allow update: if isOperator()
        && resource.data.operatorId == request.auth.uid
        && request.resource.data.packageLocations is list
        && request.resource.data.packageLocations.size() >= 1
        && request.resource.data.inclusions is list
        && request.resource.data.exclusions is list;
      allow delete: if isOperator()
        && resource.data.operatorId == request.auth.uid;
      allow write: if isSuperAdmin();
    }

    match /timeslots/{slotId} {
      allow read: if true;
      allow write: if false;
    }
		// Promo: client validates by code via query + optional operator lookup.
    match /voucherCodes/{voucherId} {
      allow read: if true;
      // ── CHANGED 2026-05-07 ─────────────────────────────────────────
      // Operators can create/manage their own voucher codes.
      // Super admins can still view/disable/manage all voucher codes.
      allow create: if isOperator()
        && request.resource.data.operatorUid == request.auth.uid;
      allow update: if isOperator()
        && resource.data.operatorUid == request.auth.uid
        && request.resource.data.operatorUid == resource.data.operatorUid;
      allow delete: if isOperator()
        && resource.data.operatorUid == request.auth.uid;
      allow create, update, delete: if isSuperAdmin();
    }

    // ── CHANGED 2026-05-07 ───────────────────────────────────────────
    // Entities: operators can only read entities they created OR are associated with.
    // Association is tracked in `associatedOperatorUids`.
    match /entities/{entityId} {
      allow read: if isSuperAdmin()
        || (isOperator()
          && (
            resource.data.createdByUid == request.auth.uid
            || (
              resource.data.associatedOperatorUids != null
              && request.auth.uid in resource.data.associatedOperatorUids
            )
          ));
      allow create: if isOperator()
        && request.resource.data.createdByUid == request.auth.uid;
      allow update: if isOperator()
        && resource.data.createdByUid == request.auth.uid
        && request.resource.data.createdByUid == resource.data.createdByUid;
      allow delete: if isOperator()
        && resource.data.createdByUid == request.auth.uid;
      allow create, update, delete: if isSuperAdmin();
    }


    // Users collection
    match /users/{userId} {
      // Any authenticated user can read their own profile
      allow read: if isOwnUserDoc(userId);
      // ── CHANGED 2026-05-07 ─────────────────────────────────────────
      // Operators can update limited self-service fields from settings page.
      // Operators can update their own profile/payment options only.
      // Added 2026-05-20 — ISSUE-001a: seal fields locked on self-update; ISSUE-001c: custom chip list shape/cap
      // Updated 2026-05-22 — ISSUE-007: chip shape only checked when those fields are actually being changed
      allow update: if isOperator()
        && isOwnUserDoc(userId)
        && operatorSealFieldsUnchanged()
        && isAllowedSelfUserUpdate()
        && customInclusionChipsShapeOk()
        && customExclusionChipsShapeOk();
      // Super admins can read and update any user
      allow read, update: if isSuperAdmin();

			// Public can read ONLY operator docs that are explicitly public-safe.
      allow get, list: if resource.data.role == "operator"
        && resource.data.status == "active";

      // ── ADDED 2026-05-07 ───────────────────────────────────────────
      // In-app notifications (TASK-64/65): server creates; user reads + marks read
      match /notifications/{notifId} {
        allow read, update: if request.auth != null && request.auth.uid == userId;
        allow create, delete: if false;
      }

    }

    // ── ADDED 2026-05-07 ───────────────────────────────────────────
    // Reviews: public read when status is approved (guest catalog + reviews-service).
    // Super admins read/update/delete all (moderation UI). Client create disabled until TASK-69.
    match /reviews/{reviewId} {
      allow read: if resource.data.status == 'approved' || isSuperAdmin();
      allow create: if false;
      allow update, delete: if isSuperAdmin();
    }

    // Operator signup requests
    match /operator_signup_requests/{requestId} {
      allow read: if isSuperAdmin();
      // Public create so unauthenticated applicants can submit
      allow create: if true;
    }

    // App config
    match /app_config/{docId} {
      allow read, write: if isSuperAdmin();
    }

    // Signup link — public read/delete for token validation & invalidation
    match /app_config/operator_signup_link {
      allow read, delete: if true;
    }

    // Platform pricing — public read for guest checkout; super-admin write
    match /app_config/pricing {
      allow read: if true;
      allow write: if isSuperAdmin();
    }

    // ── ADDED 2026-05-11 ───────────────────────────────────────────
    // Homepage CMS singleton (TASK-53). Public read so the guest landing page can
    // SSR the doc + client editor can subscribe. Super admins are the only writers.
    match /homepage_cms/{docId} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }

    // ── ADDED 2026-05-22 — ISSUE-007 ──────────────────────────────
    // Payments: only the Functions admin SDK writes here. Make intent explicit
    // and protect against future client code drift.
    match /payments/{paymentId} {
      allow read: if isSuperAdmin();
      allow write: if false;
    }

    // ── Bookings ──────────────────────────────────────────────────
    match /bookings/{bookingId} {
      // Operators can read/update their own bookings (operatorUid must match uid)
      allow read: if isOperator()
        && resource.data.operatorUid == request.auth.uid;
      allow update: if isOperator()
        && resource.data.operatorUid == request.auth.uid
        && request.resource.data.operatorUid == resource.data.operatorUid;
      // Public create for guest booking flow, but operator must match source owner.
      allow create: if bookingSourceType() in ['activity', 'tourPackage']
        && bookingSourceId() is string
        && bookingOperatorUid() is string
        && bookingMatchesSourceOwner();
      // Super admins have full access
      allow read, write: if isSuperAdmin();
    }
  }
}
