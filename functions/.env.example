# Copy to functions/.env and set your real origins before deploying.
# Comma-separated list of browser origins allowed to call the booking API.
ALLOWED_ORIGINS=http://localhost:3000,https://YOUR-APP-HOST.web.app,https://YOUR-APP-HOST.firebaseapp.com

# App URL for links in operator approval / review emails (separate from ALLOWED_ORIGINS)
# Staging example:
# APP_URL=https://bookingsystem-staging--alegria-booking-system.asia-southeast1.hosted.app
APP_URL=http://localhost:3000

# SMTP (required for signup / approval / decline emails)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=noreply@example.com

# Optional
# APP_CHECK_ENFORCE=true
