rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    function isSuperAdmin() {
      return request.auth != null
        && firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'super_admin';
    }

    // ── ADDED 2026-05-11 ───────────────────────────────────────────
    // Homepage CMS best-pictures (TASK-53). Public read for the guest landing page
    // ticker; only super admins may upload. JPEG/PNG, max 5 MB (matches admin uploader).
    match /homepage_cms/{allPaths=**} {
      allow read: if true;
      allow write: if isSuperAdmin()
                   && request.resource != null
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/(jpeg|png)');
    }

    match /profile-pictures/{filename} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // ── ADDED 2026-04-24 ───────────────────────────────────────────
    // User avatars: wired from super-admin Settings page (profile photo upload).
    // Owner-only write, any authenticated user may read. Image files, max 5MB.
    match /users/{uid}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.auth.uid == uid
                   && request.resource != null
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    // ── ADDED 2026-04-24 ───────────────────────────────────────────
    // Activity images: operators write only under their own uid folder, public read
    match /activities/{operatorId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.auth.uid == operatorId
                   && request.resource != null
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    // ── ADDED 2026-04-24 ───────────────────────────────────────────
    // Tour package images: operators write only under their own uid folder, public read
    match /tour-packages/{operatorId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.auth.uid == operatorId
                   && request.resource != null
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    // Added 2026-05-20 — ISSUE-001a: DOT proof upload (operators/{uid}/dot-proof, PDF/JPEG/PNG, 5MB)
    match /operators/{uid}/dot-proof/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && (request.auth.uid == uid || isSuperAdmin())
                   && request.resource != null
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('application/pdf|image/jpeg|image/png');
    }

    match /signup-requests/{requestId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.resource != null
                   && request.resource.size < 10 * 1024 * 1024
                   && (request.resource.contentType.matches('image/.*')
                       || request.resource.contentType == 'application/pdf');
    }
  }
}