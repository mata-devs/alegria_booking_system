{
  "name": "visitcebu",
  "private": true,
  "version": "0.0.0",
  "scripts": {
    "dev": "next dev --turbopack -H 0.0.0.0 -p 3000",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:rules": "vitest run --config vitest.rules.config.ts",
    "test:storage-rules": "vitest run --config vitest.storage-rules.config.ts",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "scan:sonar": "sonar",
    "scan": "trivy fs --scanners vuln,secret,misconfig,license --severity HIGH,CRITICAL .",
    "scan:vuln": "trivy fs --scanners vuln --severity HIGH,CRITICAL .",
    "scan:secrets": "trivy fs --scanners secret .",
    "scan:license": "trivy fs --scanners license ."
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@radix-ui/react-slot": "^1.2.4",
    "@sankyu/react-circle-flags": "^1.6.7",
    "@tanstack/react-table": "^8.21.3",
    "@types/leaflet": "^1.9.21",
    "@zxing/browser": "^0.2.0",
    "@zxing/library": "^0.23.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "country-data-list": "^1.6.2",
    "firebase": "^12.9.0",
    "firebase-admin": "^13.9.0",
    "framer-motion": "^12.40.0",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.562.0",
    "next": "^15.1.15",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-icons": "^5.6.0",
    "react-leaflet": "^5.0.0",
    "react-qr-code": "^2.0.18",
    "recharts": "^2.15.4",
    "server-only": "^0.0.1",
    "tailwind-merge": "^3.5.0",
    "vaul": "^1.1.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@firebase/rules-unit-testing": "^5.0.1",
    "@next/eslint-plugin-next": "^15.5.18",
    "@playwright/test": "^1.59.1",
    "@sonar/scan": "^4.3.6",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^6.0.2",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.39.4",
    "eslint-config-next": "^15.5.18",
    "jsdom": "^29.1.1",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5",
    "vitest": "^4.1.7"
  }
}
